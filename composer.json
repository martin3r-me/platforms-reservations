{
  "name": "martin3r/platforms-reservations",
  "description": "PausePlus – Reservation & Pre-order system for theater gastronomy",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Platform Team",
      "email": "team@platform.com"
    }
  ],
  "require": {
    "mollie/mollie-api-php": "^2.0"
  },
  "autoload": {
    "psr-4": {
      "Platform\\Reservation\\": "src/",
      "Platform\\Reservation\\Database\\Seeders\\": "database/seeders/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Platform\\Reservation\\ReservationServiceProvider"
      ]
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}
